# Normalise line endings so files behave in the Linux container / CI regardless
# of the Windows checkout. LF is enforced for anything executed on Linux.
* text=auto

*.sh      text eol=lf
*.py      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
Dockerfile text eol=lf
*.env.example text eol=lf

# Treat binaries as-is.
*.pem  binary
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.wav  binary
