# ---------------------------------------------------------------------------
# Tax Agent configuration template.
# Copy to `.env` and fill in only what you need. The app runs fully with the
# defaults below (LLM_PROVIDER=mock) -- no credentials required.
# ---------------------------------------------------------------------------

# -- Environment
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=text

# -- LLM (Tax Agent chat)
# mock = fully offline; anthropic = Claude (needs `pip install anthropic` + key)
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
LLM_MAX_TOKENS=16000
# Mock realism knobs
MOCK_STREAM_DELAY_MS=14
MOCK_FAILURE_RATE=0.0

# -- RAG
RAG_CORPUS_DIR=rag/corpus
RAG_TOP_K=8
RAG_RERANK_TOP_N=4

# -- Security guardrails
ENABLE_GUARDRAILS=true
SECURITY_BLOCK_THRESHOLD=0.80
SECURITY_FLAG_THRESHOLD=0.45
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_BURST=10
AUDIT_LOG_PATH=data/audit.jsonl

# -- Chat
MAX_MESSAGE_CHARS=8000
MAX_ATTACHMENT_MB=5
CONVERSATION_DIR=data/conversations

# -- Provider selection
# One of: mock | azure | gcp | aws
DEFAULT_PROVIDER=mock
# Comma / JSON list is parsed by pydantic-settings; leaving the default is fine.
# FALLBACK_PROVIDERS=["gcp","aws","azure","mock"]

# -- Local speech-to-text (used by the mock provider; needs faster-whisper)
# The model (~75 MB for "tiny") downloads from Hugging Face on first load.
ENABLE_LOCAL_STT=true
LOCAL_STT_MODEL=tiny

# -- Agent
USE_MOCK_AGENT=true
AGENT_API_URL=http://localhost:9000

# -- Limits
MAX_TEXT_CHARS=1000
MAX_AUDIO_SIZE_MB=3
MAX_AUDIO_DURATION_SECONDS=60

# -- Azure (Translator works over REST with just a key)
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=centralindia
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=centralindia

# -- GCP (requires google-cloud-translate / google-cloud-speech installed)
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# -- AWS (requires boto3 installed)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
